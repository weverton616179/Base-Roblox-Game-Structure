		<Item class="Script" referent="RBX2810E0E5ECFA472AB222F6DFF5B85481">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local car = script.Parent
local LightsEvent = car:WaitForChild("LightsEvent")
local lightsFolder = car.Body.Lights
local interface = car["A-Chassis Tune"]["A-Chassis Interface"]
local lightsValue = interface.Values:WaitForChild("Lights")

-- Função para controlar todas as luzes do tipo especificado
local function controlLights(folderName, enabled)
	local folder = lightsFolder:FindFirstChild(folderName)
	if folder then
		for _, part in folder:GetDescendants() do
			if part:IsA("SpotLight") then
				part.Enabled = enabled
			end
		end
	end
end

-- Função principal para controlar todas as luzes
local function updateAllLights(enabled)
	-- Faróis principais
	controlLights("HeadLights", enabled)
	-- Você pode adicionar outros tipos de luzes aqui
	-- controlLights("ParkingLights", enabled)
	-- controlLights("BrakeLights", enabled)
end

-- Conectar ao evento do cliente
LightsEvent.OnServerEvent:Connect(function(player, lightsState)
	-- Validar se o jogador está no carro
	local seat = car.DriveSeat
	if seat.Occupant and seat.Occupant.Parent == player.Character then
		-- Atualizar o valor compartilhado
		lightsValue.Value = lightsState
		-- Aplicar mudança nas luzes (servidor)
		updateAllLights(lightsState)
		-- Replicar para todos os clientes
		LightsEvent:FireAllClients(lightsState)
	end
end)

-- Sincronizar quando jogador entra no carro
car.DriveSeat.ChildAdded:Connect(function(child)
	if child:IsA("Weld") and child.Name == "SeatWeld" then
		-- Enviar estado atual para o novo jogador
		task.wait(0.5)
		LightsEvent:FireAllClients(lightsValue.Value)
	end
end)

print("LightsController iniciado")]]></ProtectedString>
