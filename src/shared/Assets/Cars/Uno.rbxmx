							<Properties>
								<ProtectedString name="Source"><![CDATA[task.wait()

local event = script.Parent

local car = script.Parent.Parent
local lights = car.Body.Lights

local HazardsActive = false
local LeftBlinkActive = false
local RightBlinkActive = false

local LeftBlink = lights.LeftBlinkerLights
local RightBlink = lights.RightBlinkerLights
local HeadLights = lights.HeadLights
local BrakeLights = lights.BrakeLights
local ParkingLights = lights.ParkingLights
local ReverseLights = lights.ReverseLights

local function TurnOnOffLight(folder, bool)
	local Transparency
	if bool then Transparency = 0 else Transparency = 1 end
	for _, part : BasePart in pairs(folder:GetChildren()) do
		if part:IsA("BasePart") or part:IsA("MeshPart") or part:IsA("Part") then
			part.Transparency = Transparency
			local luz
			
			if part:FindFirstChild("SurfaceLight") then luz = part:FindFirstChild("SurfaceLight")
			elseif part:FindFirstChild("SpotLight") then luz = part:FindFirstChild("SpotLight")
			elseif part:FindFirstChild("PointLight") then luz = part:FindFirstChild("PointLight")
			else luz = nil end
			if luz then
				luz.Enabled = bool
			end
		end
	end
end

local function BlinkR(bool)
	if bool then
		RightBlinkActive = true
		local active = true
		while RightBlinkActive do
			TurnOnOffLight(RightBlink, active)
			active = not active
			task.wait(.5)
		end
	else
		RightBlinkActive = false
		TurnOnOffLight(RightBlink, bool)
	end
end

local function BlinkL(bool)
	if bool then
		LeftBlinkActive = true
		local active = true
		while LeftBlinkActive do
			TurnOnOffLight(LeftBlink, active)
			active = not active
			task.wait(.5)
		end
	else
		LeftBlinkActive = false
		TurnOnOffLight(LeftBlink, bool)
	end
end

local function Hazards(bool)
	if bool then
		HazardsActive = true
		
		while HazardsActive do
			TurnOnOffLight(LeftBlink, true)
			TurnOnOffLight(RightBlink, true)
			task.wait(.5)
			TurnOnOffLight(LeftBlink, false)
			TurnOnOffLight(RightBlink, false)
			task.wait(.5)
		end
	else
		HazardsActive = false
	end
end

event.OnServerEvent:Connect(function(player, val, bool)
	print("servidor", player, bool, val)
	if val == "LeftBlink" then BlinkL(bool) 
	elseif val == "RightBlink" then BlinkR(bool)
	elseif val == "BrakeLights" then TurnOnOffLight(BrakeLights, bool) 
	elseif val == "ParkingLights" then TurnOnOffLight(ParkingLights, bool)
	elseif val == "HeadLights" then TurnOnOffLight(HeadLights, bool)
	elseif val == "Hazards" then Hazards(bool)
	elseif val == "ReverseLights" then TurnOnOffLight(ReverseLights, bool)
	end
end)]]></ProtectedString>
