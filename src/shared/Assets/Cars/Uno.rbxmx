						<Properties>
							<ProtectedString name="Source"><![CDATA[task.wait()

local car = script.Parent.Parent.Car.Value
local event = car.LightsEvent :: UnreliableRemoteEvent
local values = script.Parent.Parent.Values

local TesteLuzes = values.TesteLuzes :: BoolValue
local LeftBlink = values.LeftBlink :: BoolValue
local RightBlink = values.RightBlink :: BoolValue
local HeadLights = values.HeadLights :: BoolValue
local Hazards = values.Hazards :: BoolValue
local ParkingLights = values.ParkingLights :: BoolValue
local BrakeLights = values.BrakeLights :: BoolValue
local ReverseLights = values.ReverseLights :: BoolValue

local HeadLightButton = script.Parent.Advanced.HeadLightButton
local LeftBlinkButton = script.Parent.Advanced.LeftBlinkButton
local RightBlinkButton = script.Parent.Advanced.RightBlinkButton
local HazardsButton = script.Parent.Advanced.HazardsButton

local HazardsActive = false
local LeftBlinkActive = false
local RightBlinkActive = false

local UserInputService = game:GetService("UserInputService")
UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
	if not gameProcessedEvent then
		if input.KeyCode == Enum.KeyCode.V or input.KeyCode == Enum.KeyCode.ButtonL3 then
			script.Parent.Visible = not script.Parent.Visible
		end
	end
end)

local function HeadLightController(val, bool)
	if val == "HeadLights" then
		if bool then HeadLightButton.ImageColor3 = Color3.fromRGB(30, 30, 255) HeadLightButton.ImageTransparency = 0
		else HeadLightButton.ImageColor3 = Color3.fromRGB(0, 0, 0) HeadLightButton.ImageTransparency = 0.8 end
	elseif val == "ParkingLights" then	
		if bool then HeadLightButton.ImageColor3 = Color3.fromRGB(255, 255, 255) HeadLightButton.ImageTransparency = 0
		else HeadLightButton.ImageColor3 = Color3.fromRGB(0, 0, 0) HeadLightButton.ImageTransparency = 0.8 end
	end
end

local function HazardsController(bool)
	if bool then
		HazardsActive = true
		
		while HazardsActive do
			HazardsButton.ImageColor3 = Color3.fromRGB(255, 255, 255)
			LeftBlinkButton.ImageColor3 = Color3.fromRGB(255, 255, 255)
			RightBlinkButton.ImageColor3 = Color3.fromRGB(255, 255, 255)
			task.wait(0.5)
			HazardsButton.ImageColor3 = Color3.fromRGB(140, 140, 140)
			LeftBlinkButton.ImageColor3 = Color3.fromRGB(140, 140, 140)
			RightBlinkButton.ImageColor3 = Color3.fromRGB(140, 140, 140)
			task.wait(0.5)
		end
	else
		HazardsActive = false
	end
		
end

local function LeftBlinkController(bool)
	if bool then
		LeftBlinkActive = true
		
		while LeftBlinkActive do
			LeftBlinkButton.ImageColor3 = Color3.fromRGB(255, 255, 255)
			task.wait(0.5)
			LeftBlinkButton.ImageColor3 = Color3.fromRGB(140, 140, 140)
			task.wait(0.5)
		end
	else
		LeftBlinkActive = false
	end
end

local function RightBlinkController(bool)
	if bool then
		RightBlinkActive = true

		while RightBlinkActive do
			RightBlinkButton.ImageColor3 = Color3.fromRGB(255, 255, 255)
			task.wait(0.5)
			RightBlinkButton.ImageColor3 = Color3.fromRGB(140, 140, 140)
			task.wait(0.5)
		end
	else
		RightBlinkActive = false
	end
end

TesteLuzes.Changed:Connect(function() event:FireServer(TesteLuzes.Name, TesteLuzes.Value) end)
LeftBlink.Changed:Connect(function() event:FireServer(LeftBlink.Name, LeftBlink.Value) LeftBlinkController(LeftBlink.Value) end) -- feito
RightBlink.Changed:Connect(function() event:FireServer(RightBlink.Name, RightBlink.Value) RightBlinkController(RightBlink.Value) end) -- feito
HeadLights.Changed:Connect(function() event:FireServer(HeadLights.Name, HeadLights.Value) HeadLightController(HeadLights.Name, HeadLights.Value) end) -- feito
Hazards.Changed:Connect(function() event:FireServer(Hazards.Name, Hazards.Value) HazardsController(Hazards.Value) end)
ParkingLights.Changed:Connect(function() event:FireServer(ParkingLights.Name, ParkingLights.Value) HeadLightController(ParkingLights.Name, ParkingLights.Value) end) -- feito
BrakeLights.Changed:Connect(function() event:FireServer(BrakeLights.Name, BrakeLights.Value) end) -- feito
ReverseLights.Changed:Connect(function() event:FireServer(ReverseLights.Name, ReverseLights.Value) end) -- feito]]></ProtectedString>
