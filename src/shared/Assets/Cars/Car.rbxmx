	 /_/    \_\     \_____|_| |_|\__,_|___/___/_|___/
	 Interface de Controle de Luzes
--]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local car = script.Parent.Car.Value
local LightsEvent = car:WaitForChild("LightsEvent")
local interface = script.Parent
local lightsValue = interface.Values:WaitForChild("Lights")

-- Criar botão para controle das luzes
local function createLightsButton()
	local screenGui = player:WaitForChild("PlayerGui"):FindFirstChild("A-Chassis Interface")
	if not screenGui then return end
	
	local button = Instance.new("TextButton")
	button.Name = "LightsButton"
	button.Size = UDim2.new(0, 100, 0, 40)
	button.Position = UDim2.new(0, 10, 0, 10)
	button.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
	button.BorderSizePixel = 2
	button.BorderColor3 = Color3.new(0.5, 0.5, 0.5)
	button.Text = "Luzes: OFF"
	button.TextColor3 = Color3.new(1, 1, 1)
	button.Font = Enum.Font.SourceSansBold
	button.TextSize = 14
	button.Parent = screenGui
	
	-- Animação de hover
	local hoverTween = TweenService:Create(button, TweenInfo.new(0.2), {
		BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
	})
	
	local normalTween = TweenService:Create(button, TweenInfo.new(0.2), {
		BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
	})
	
	button.MouseEnter:Connect(function()
		hoverTween:Play()
	end)
	
	button.MouseLeave:Connect(function()
		normalTween:Play()
	end)
	
	-- Função para atualizar aparência do botão
	local function updateButtonAppearance()
		if lightsValue.Value then
			button.Text = "Luzes: ON"
			button.BackgroundColor3 = Color3.new(0.2, 0.6, 0.2)
			button.BorderColor3 = Color3.new(0.4, 0.8, 0.4)
		else
			button.Text = "Luzes: OFF"
			button.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
			button.BorderColor3 = Color3.new(0.5, 0.5, 0.5)
		end
	end
	
	-- Conectar clique do botão
	button.MouseButton1Click:Connect(function()
		local newState = not lightsValue.Value
		LightsEvent:FireServer(newState)
	end)
	
	-- Sincronizar com mudanças no valor
	lightsValue.Changed:Connect(updateButtonAppearance)
	
	-- Estado inicial
	updateButtonAppearance()
	
	return button
end

-- Função para controlar luzes locais
local function updateLocalLights(enabled)
	local lightsFolder = car.Body.Lights
	
	-- Faróis principais
	local headLights = lightsFolder:FindFirstChild("HeadLights")
	if headLights then
		for _, part in headLights:GetDescendants() do
			if part:IsA("SpotLight") then
				part.Enabled = enabled
			end
		end
	end
	
	-- Você pode adicionar outros tipos de luzes aqui
	-- local parkingLights = lightsFolder:FindFirstChild("ParkingLights")
	-- if parkingLights then
	-- 	for _, part in parkingLights:GetDescendants() do
	-- 		if part:IsA("SpotLight") then
	-- 			part.Enabled = enabled
	-- 		end
	-- 	end
	-- end
end

-- Conectar ao evento do servidor
LightsEvent.OnClientEvent:Connect(function(lightsState)
	updateLocalLights(lightsState)
end)

-- Sincronizar com mudanças no valor compartilhado
lightsValue.Changed:Connect(updateLocalLights)

-- Criar interface quando jogador entrar no carro
player.CharacterAdded:Connect(function(character)
	character:WaitForChild("Humanoid")
	task.wait(1)
	createLightsButton()
end)

-- Se já estiver no jogo
if player.Character then
	task.wait(1)
	createLightsButton()
end

print("LightsControl iniciado")]]></ProtectedString>
