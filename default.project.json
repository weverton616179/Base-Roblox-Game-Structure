{
  "name": "testGangLandesVscode",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Packages": {
        "$path": "roblox_packages"
      },

      "Shared": {
        "$path": "src/shared",

        "Network": {
          "$path": "src/network/archives"
        },

        "Utils": {
          "$path": "src/services/utils"
        }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server",

        "Services": {
          "$path": "src/services/services"
        }
      },
      "ServerPackages" : {
        "$path" : "roblox_server_packages"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client",

          "Controller": {
            "$path": "src/services/controller"
          }
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [
            0.38823,
            0.37254,
            0.38823
          ],
          "Locked": true,
          "Position": [
            0,
            -10,
            0
          ],
          "Size": [
            512,
            20,
            512
          ]
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}